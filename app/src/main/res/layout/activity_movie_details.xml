<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="320dp">

                <ImageView
                    android:id="@+id/iv_backdrop"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:scaleType="centerCrop"
                    android:alpha="0.6"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:background="@drawable/gradient_overlay"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="110dp"
                    android:layout_height="160dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="120dp"
                    app:cardCornerRadius="12dp">
                    <ImageView
                        android:id="@+id/iv_details_poster"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="130dp"
                    android:layout_marginLeft="145dp"
                    android:layout_marginRight="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_details_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_details_date_runtime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#9BA3AF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_details_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rating_bg"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:text="Overview"
                android:textColor="#90CEA1"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="16dp">
                <TextView
                    android:id="@+id/tv_details_overview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:textColor="#B0B8C1"
                    android:lineSpacingExtra="4dp"
                    android:textSize="14sp" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="10dp"
                android:text="About movie"
                android:textColor="#90CEA1"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="16dp">

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:stretchColumns="1">

                    <TableRow android:layout_marginBottom="8dp">
                        <TextView android:text="Status" android:textColor="#9BA3AF" android:textSize="14sp" />
                        <TextView android:id="@+id/tv_status" android:textColor="#FFFFFF" android:gravity="end" android:text="Released" />
                    </TableRow>

                    <TableRow android:layout_marginBottom="8dp">
                        <TextView android:text="Budget" android:textColor="#9BA3AF" android:textSize="14sp" />
                        <TextView android:id="@+id/tv_budget" android:textColor="#FFFFFF" android:gravity="end" />
                    </TableRow>

                    <TableRow android:layout_marginBottom="8dp">
                        <TextView android:text="Revenue" android:textColor="#9BA3AF" android:textSize="14sp" />
                        <TextView android:id="@+id/tv_revenue" android:textColor="#FFFFFF" android:gravity="end" />
                    </TableRow>

                    <TableRow>
                        <TextView android:text="Country" android:textColor="#9BA3AF" android:textSize="14sp" />
                        <TextView android:id="@+id/tv_country" android:textColor="#FFFFFF" android:gravity="end" />
                    </TableRow>
                </TableLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="10dp"
                android:text="Top Billed Cast"
                android:textColor="#90CEA1"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_cast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingLeft="16dp"
                android:paddingBottom="24dp"
                android:clipToPadding="false"
                android:orientation="horizontal" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>